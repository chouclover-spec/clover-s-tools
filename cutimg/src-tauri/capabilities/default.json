{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl-manifests/acl-manifests.json",
  "identifier": "default",
  "description": "Default capabilities for CutImg",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "shell:allow-open"
  ]
}